# Variables para levantar docker-compose.yml completo (db + api + web)

# --- PostgreSQL / API ---
DB_NAME=hecos
DB_USER=hecos
DB_PASSWORD=hecos
PORT=8080

# --- API: Google OAuth2 / JWT ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# --- Frontend (build-time, Vite las embebe en el bundle en compilación) ---
VITE_API_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=
