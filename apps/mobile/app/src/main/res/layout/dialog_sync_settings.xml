<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchAutoSync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auto_sync_enable" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_sync_frequency"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/radioGroupFrequency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/radioFreq1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_sync_every_1h" />

        <RadioButton
            android:id="@+id/radioFreq6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_sync_every_6h" />

        <RadioButton
            android:id="@+id/radioFreq12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_sync_every_12h" />

        <RadioButton
            android:id="@+id/radioFreq24"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_sync_every_24h" />

    </RadioGroup>

</LinearLayout>
